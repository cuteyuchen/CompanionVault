{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CompanionVault Persona",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "version",
    "locale",
    "name",
    "summary",
    "license",
    "tags",
    "identity",
    "personality",
    "features",
    "voice",
    "emotional_behavior",
    "relationship",
    "memory",
    "safety"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "locale": {"type": "string", "minLength": 2},
    "name": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 10},
    "license": {"type": "string"},
    "tags": {"type": "array", "minItems": 2, "items": {"type": "string"}, "uniqueItems": true},
    "author": {"type": "object"},
    "baseline": {"type": "array", "items": {"type": "string"}},
    "identity": {"type": "object", "required": ["role", "self_concept", "relationship_start"]},
    "personality": {"type": "object", "required": ["core_traits", "strengths", "flaws", "values"], "properties": {"core_traits": {"type": "array", "minItems": 3}, "strengths": {"type": "array", "minItems": 2}, "flaws": {"type": "array", "minItems": 1}, "values": {"type": "array", "minItems": 2}}},
    "features": {"type": "array", "minItems": 3},
    "voice": {"type": "object", "required": ["language", "default_length", "sentence_style", "habits", "avoid"]},
    "emotional_behavior": {"type": "object"},
    "relationship": {"type": "object", "required": ["progression", "conflict_repair"]},
    "memory": {"type": "object", "required": ["remember", "never_invent"]},
    "safety": {"type": "object", "required": ["no_exclusivity", "no_dependency_pressure", "no_professional_claims", "respect_real_relationships"]}
  },
  "additionalProperties": true
}